{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "schedule": [
    "after 10pm every weekday",
    "every weekend",
    "before 5am every weekday"
  ],
  "enabledManagers": [
    "pep621",
    "github-actions",
    "pre-commit",
    "custom.regex"
  ],
  "minimumReleaseAge": "14 days",
  "osvVulnerabilityAlerts": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update gogcli version in dependencies.json",
      "managerFilePatterns": [
        "/skills/google/dependencies\\.json$/"
      ],
      "matchStrings": ["\"version\":\\s*\"(?<currentValue>[^\"]+)\"[\\s\\S]*?\"repository\":\\s*\"(?<packageName>[^\"]+)\""],
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge patch and minor updates when CI passes",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "description": "Group ruff-related updates",
      "matchPackageNames": [
        "ruff",
        "ruff-pre-commit",
        "astral-sh/ruff-pre-commit"
      ],
      "groupName": "ruff"
    },
    {
      "description": "Group pytest-related updates",
      "matchPackageNames": [
        "pytest",
        "pytest-cov"
      ],
      "groupName": "pytest"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "description": "gogcli: require manual merge and security validation",
      "matchPackageNames": [
        "openclaw/gogcli"
      ],
      "automerge": false,
      "minimumReleaseAge": "7 days"
    }
  ]
}
